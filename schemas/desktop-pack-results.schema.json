{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gaoxia.local/long-novel-agent/desktop-pack-results.schema.json",
  "title": "Long Novel Agent Desktop Verification Results",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "$schema",
    "checks"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "minLength": 1
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/check"
      }
    }
  },
  "$defs": {
    "check": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "id",
        "status",
        "evidence",
        "notes"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "status": {
          "enum": [
            "passed",
            "failed",
            "skipped",
            "not_checked"
          ]
        },
        "evidence": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
