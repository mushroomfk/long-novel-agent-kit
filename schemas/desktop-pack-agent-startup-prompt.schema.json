{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://long-novel-agent.local/schemas/desktop-pack-agent-startup-prompt.schema.json",
  "title": "Long Novel Agent Startup Prompt",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "$schema",
    "ok",
    "type",
    "generated_at",
    "local_only",
    "requires_server",
    "would_write_project_state",
    "would_write_install_config",
    "would_write_pack_files",
    "records_real_client_evidence",
    "project_dir",
    "platform",
    "mode",
    "target_chapter",
    "status",
    "copy_prompt",
    "summary",
    "read_first",
    "tool_gates",
    "write_boundaries",
    "commands",
    "source_files"
  ],
  "properties": {
    "$schema": {
      "const": "agent-startup-prompt.schema.json"
    },
    "ok": {
      "type": "boolean"
    },
    "type": {
      "const": "agent_startup_prompt"
    },
    "generated_at": {
      "type": "string"
    },
    "local_only": {
      "const": true
    },
    "requires_server": {
      "const": false
    },
    "would_write_project_state": {
      "const": false
    },
    "would_write_install_config": {
      "const": false
    },
    "would_write_pack_files": {
      "const": false
    },
    "records_real_client_evidence": {
      "const": false
    },
    "project_dir": {
      "type": ["string", "null"]
    },
    "output_dir": {
      "type": ["string", "null"]
    },
    "platform": {
      "type": ["string", "null"]
    },
    "mode": {
      "type": ["string", "null"]
    },
    "target_chapter": {
      "type": "integer",
      "minimum": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "ready_to_prompt",
        "ready_for_read_only_start",
        "needs_author_review",
        "needs_continuity_fix",
        "needs_initialization",
        "needs_pack_repair"
      ]
    },
    "can_draft": {
      "type": "boolean"
    },
    "copy_prompt": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "project_readiness",
        "agent_takeover_status",
        "chapter_session_freshness_status",
        "author_review_queue_status",
        "continuity_must_fix",
        "continuity_review",
        "chapter_session_status"
      ]
    },
    "read_first": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["file", "why"],
        "properties": {
          "file": {
            "type": "string",
            "minLength": 1
          },
          "why": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "tool_gates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "write_boundaries": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "agent_startup_prompt_is_read_only",
        "do_not_write_project_state_from_this_prompt",
        "read_only_agents_must_not_execute",
        "writer_actions_need_author_confirmation",
        "real_gui_evidence_is_separate_from_local_cli_checks"
      ],
      "properties": {
        "agent_startup_prompt_is_read_only": {
          "const": true
        },
        "do_not_write_project_state_from_this_prompt": {
          "const": true
        },
        "read_only_agents_must_not_execute": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "writer_actions_need_author_confirmation": {
          "const": true
        },
        "real_gui_evidence_is_separate_from_local_cli_checks": {
          "const": true
        }
      }
    },
    "commands": {
      "type": "object",
      "additionalProperties": true
    },
    "source_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "read_errors": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    }
  }
}
