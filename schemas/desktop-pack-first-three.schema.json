{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://long-novel-agent.local/schemas/desktop-pack-first-three.schema.json",
  "title": "Long Novel Agent First Three",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "$schema",
    "type",
    "ok",
    "generated_at",
    "kit_version",
    "local_only",
    "requires_server",
    "would_write_project_state",
    "would_write_install_config",
    "would_write_pack_files",
    "records_real_client_evidence",
    "project_dir",
    "output_dir",
    "platform",
    "mode",
    "tool_profile",
    "target_chapter",
    "status",
    "headline",
    "primary_action",
    "summary",
    "files",
    "read_after_three",
    "write_boundaries",
    "notes"
  ],
  "properties": {
    "$schema": {
      "const": "first-three.schema.json"
    },
    "type": {
      "const": "desktop_first_three"
    },
    "ok": {
      "type": "boolean"
    },
    "generated_at": {
      "type": "string"
    },
    "kit_version": {
      "type": "string"
    },
    "local_only": {
      "const": true
    },
    "requires_server": {
      "const": false
    },
    "would_write_project_state": {
      "const": false
    },
    "would_write_install_config": {
      "const": false
    },
    "would_write_pack_files": {
      "const": false
    },
    "records_real_client_evidence": {
      "const": false
    },
    "project_dir": {
      "type": ["string", "null"]
    },
    "output_dir": {
      "type": ["string", "null"]
    },
    "platform": {
      "type": ["string", "null"]
    },
    "mode": {
      "type": ["string", "null"]
    },
    "tool_profile": {
      "type": ["string", "null"]
    },
    "target_chapter": {
      "type": "integer",
      "minimum": 1
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "headline": {
      "type": "string",
      "minLength": 1
    },
    "primary_action": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "id",
        "title",
        "file",
        "writes_project_state",
        "writes_install_config",
        "writes_pack_files",
        "records_real_client_evidence"
      ],
      "properties": {
        "id": {
          "type": ["string", "null"]
        },
        "title": {
          "type": ["string", "null"]
        },
        "file": {
          "type": ["string", "null"]
        },
        "writes_project_state": {
          "const": false
        },
        "writes_install_config": {
          "const": false
        },
        "writes_pack_files": {
          "const": false
        },
        "records_real_client_evidence": {
          "const": false
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": true
    },
    "files": {
      "type": "array",
      "minItems": 3,
      "items": {
        "$ref": "#/$defs/fileEntry"
      }
    },
    "read_after_three": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "write_boundaries": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "first_three_is_read_only",
        "do_not_execute_writer_commands_from_this_file",
        "local_cli_checks_do_not_replace_real_gui_client_evidence",
        "writer_actions_need_author_confirmation"
      ],
      "properties": {
        "first_three_is_read_only": {
          "const": true
        },
        "do_not_execute_writer_commands_from_this_file": {
          "const": true
        },
        "local_cli_checks_do_not_replace_real_gui_client_evidence": {
          "const": true
        },
        "writer_actions_need_author_confirmation": {
          "const": true
        }
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "fileEntry": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "order",
        "file",
        "title",
        "audience",
        "why",
        "machine_file",
        "schema",
        "writes_project_state",
        "writes_install_config",
        "writes_pack_files",
        "records_real_client_evidence"
      ],
      "properties": {
        "order": {
          "type": "integer",
          "minimum": 1
        },
        "file": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "audience": {
          "enum": ["ordinary_user", "desktop_agent"]
        },
        "why": {
          "type": "string",
          "minLength": 1
        },
        "machine_file": {
          "type": "string",
          "minLength": 1
        },
        "schema": {
          "type": "string",
          "minLength": 1
        },
        "writes_project_state": {
          "const": false
        },
        "writes_install_config": {
          "const": false
        },
        "writes_pack_files": {
          "const": false
        },
        "records_real_client_evidence": {
          "const": false
        }
      }
    }
  }
}
