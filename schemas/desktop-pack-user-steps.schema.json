{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://long-novel-agent.local/schemas/desktop-pack-user-steps.schema.json",
  "title": "Long Novel Agent User Steps",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "$schema",
    "ok",
    "type",
    "generated_at",
    "local_only",
    "requires_server",
    "would_write_project_state",
    "would_write_install_config",
    "would_write_pack_files",
    "records_real_client_evidence",
    "project_dir",
    "output_dir",
    "platform",
    "mode",
    "tool_profile",
    "target_chapter",
    "status",
    "headline",
    "primary_action",
    "summary",
    "step_count",
    "steps",
    "read_first",
    "write_boundaries",
    "source_files"
  ],
  "properties": {
    "$schema": {
      "const": "user-steps.schema.json"
    },
    "ok": {
      "type": "boolean"
    },
    "type": {
      "const": "desktop_user_steps"
    },
    "generated_at": {
      "type": "string"
    },
    "local_only": {
      "const": true
    },
    "requires_server": {
      "const": false
    },
    "would_write_project_state": {
      "const": false
    },
    "would_write_install_config": {
      "const": false
    },
    "would_write_pack_files": {
      "const": false
    },
    "records_real_client_evidence": {
      "const": false
    },
    "project_dir": {
      "type": ["string", "null"]
    },
    "output_dir": {
      "type": ["string", "null"]
    },
    "platform": {
      "type": ["string", "null"]
    },
    "mode": {
      "type": ["string", "null"]
    },
    "tool_profile": {
      "type": ["string", "null"]
    },
    "target_chapter": {
      "type": "integer",
      "minimum": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "unknown",
        "needs_pack_repair",
        "needs_fresh_pack",
        "needs_initialization",
        "needs_real_client_evidence",
        "needs_author_review",
        "ready_with_warnings",
        "ready_to_start"
      ]
    },
    "headline": {
      "type": "string"
    },
    "primary_action": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "title", "status", "command_key", "file"],
      "properties": {
        "id": {
          "type": ["string", "null"]
        },
        "title": {
          "type": ["string", "null"]
        },
        "status": {
          "type": ["string", "null"]
        },
        "command_key": {
          "type": ["string", "null"]
        },
        "file": {
          "type": ["string", "null"]
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "project_readiness",
        "desktop_next_step_status",
        "desktop_pack_readiness_status",
        "pack_freshness_status",
        "chapter_session_freshness_status",
        "author_review_queue_status",
        "desktop_evidence_review_status"
      ]
    },
    "step_count": {
      "const": 5
    },
    "steps": {
      "type": "array",
      "minItems": 5,
      "items": {
        "$ref": "#/$defs/step"
      }
    },
    "read_first": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "write_boundaries": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "user_steps_is_read_only",
        "local_checks_do_not_prove_gui_client_access",
        "record_desktop_check_writes_verification_log",
        "writer_mode_requires_author_review",
        "remote_connector_only_platforms_are_outside_this_local_flow"
      ],
      "properties": {
        "user_steps_is_read_only": {
          "const": true
        },
        "local_checks_do_not_prove_gui_client_access": {
          "const": true
        },
        "record_desktop_check_writes_verification_log": {
          "const": true
        },
        "writer_mode_requires_author_review": {
          "const": true
        },
        "remote_connector_only_platforms_are_outside_this_local_flow": {
          "const": true
        }
      }
    },
    "source_files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "read_errors": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "source": {
      "type": "string"
    },
    "pack_dir": {
      "type": "string"
    }
  },
  "$defs": {
    "commandRef": {
      "type": "object",
      "additionalProperties": true,
      "required": ["key", "present", "command"],
      "properties": {
        "key": {
          "type": "string",
          "minLength": 1
        },
        "present": {
          "type": "boolean"
        },
        "command": {
          "type": "string"
        }
      }
    },
    "step": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "index",
        "id",
        "title",
        "goal",
        "read",
        "commands",
        "expected",
        "stop_if",
        "write_boundary"
      ],
      "properties": {
        "index": {
          "type": "integer",
          "minimum": 1
        },
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "goal": {
          "type": "string",
          "minLength": 1
        },
        "read": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "commands": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/commandRef"
          }
        },
        "expected": {
          "type": "string",
          "minLength": 1
        },
        "stop_if": {
          "type": "string"
        },
        "write_boundary": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
