{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gaoxia.local/long-novel-agent/desktop-pack-author-actions.schema.json",
  "title": "Long Novel Agent Author Actions",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "$schema",
    "ok",
    "type",
    "generated_at",
    "local_only",
    "requires_server",
    "would_write_project_state",
    "would_write_install_config",
    "would_write_pack_files",
    "records_real_client_evidence",
    "project_dir",
    "output_dir",
    "platform",
    "mode",
    "target_chapter",
    "status",
    "summary",
    "action_groups",
    "decision_options",
    "write_boundaries",
    "source_files",
    "notes"
  ],
  "properties": {
    "$schema": {
      "const": "author-actions.schema.json"
    },
    "ok": {
      "type": "boolean"
    },
    "type": {
      "const": "author_actions"
    },
    "generated_at": {
      "type": "string"
    },
    "local_only": {
      "const": true
    },
    "requires_server": {
      "const": false
    },
    "would_write_project_state": {
      "const": false
    },
    "would_write_install_config": {
      "const": false
    },
    "would_write_pack_files": {
      "const": false
    },
    "records_real_client_evidence": {
      "const": false
    },
    "project_dir": {
      "type": "string"
    },
    "output_dir": {
      "type": "string"
    },
    "platform": {
      "type": "string"
    },
    "mode": {
      "type": "string"
    },
    "target_chapter": {
      "type": "integer",
      "minimum": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "blocked",
        "needs_initialization",
        "needs_revision",
        "needs_author_review",
        "needs_real_client_evidence",
        "ready_for_author_review",
        "ready_for_read_only_work"
      ]
    },
    "summary": {
      "type": "object",
      "additionalProperties": true
    },
    "action_groups": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "id",
          "title",
          "status",
          "priority",
          "why",
          "read_files",
          "commands",
          "requires_author_decision",
          "writes_project_state",
          "writes_install_config",
          "records_real_client_evidence"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "priority": {
            "type": "integer",
            "minimum": 1
          },
          "why": {
            "type": "string"
          },
          "read_files": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "commands": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true,
              "required": [
                "key",
                "present"
              ],
              "properties": {
                "key": {
                  "type": "string"
                },
                "present": {
                  "type": "boolean"
                }
              }
            }
          },
          "requires_author_decision": {
            "type": "boolean"
          },
          "writes_project_state": {
            "type": "boolean"
          },
          "writes_install_config": {
            "type": "boolean"
          },
          "records_real_client_evidence": {
            "type": "boolean"
          }
        }
      }
    },
    "author_review_preview": {
      "type": "array"
    },
    "decision_options": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "id",
          "when",
          "read"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "when": {
            "type": "string"
          },
          "read": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "write_boundaries": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "author_actions_is_read_only",
        "do_not_write_project_state_from_this_file",
        "read_only_agents_must_not_execute",
        "writer_actions_need_author_confirmation",
        "real_gui_evidence_is_separate_from_local_cli_checks",
        "remote_connector_only_platforms_are_outside_this_pack"
      ],
      "properties": {
        "author_actions_is_read_only": {
          "const": true
        },
        "do_not_write_project_state_from_this_file": {
          "const": true
        },
        "read_only_agents_must_not_execute": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "writer_actions_need_author_confirmation": {
          "type": "boolean"
        },
        "real_gui_evidence_is_separate_from_local_cli_checks": {
          "type": "boolean"
        },
        "remote_connector_only_platforms_are_outside_this_pack": {
          "type": "boolean"
        }
      }
    },
    "source_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
