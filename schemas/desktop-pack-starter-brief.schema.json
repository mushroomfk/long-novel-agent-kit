{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://long-novel-agent.local/schemas/desktop-pack-starter-brief.schema.json",
  "title": "Long Novel Agent Starter Brief",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "$schema",
    "ok",
    "type",
    "generated_at",
    "local_only",
    "requires_server",
    "would_write_project_state",
    "would_write_install_config",
    "would_write_pack_files",
    "records_real_client_evidence",
    "project_dir",
    "output_dir",
    "platform",
    "mode",
    "target_chapter",
    "status",
    "can_draft",
    "summary",
    "next_action",
    "do_first",
    "first_files",
    "read_before_writing",
    "commands",
    "write_boundaries",
    "source_files"
  ],
  "properties": {
    "$schema": {
      "const": "starter-brief.schema.json"
    },
    "ok": {
      "type": "boolean"
    },
    "type": {
      "const": "starter_brief"
    },
    "generated_at": {
      "type": "string"
    },
    "local_only": {
      "const": true
    },
    "requires_server": {
      "const": false
    },
    "would_write_project_state": {
      "const": false
    },
    "would_write_install_config": {
      "const": false
    },
    "would_write_pack_files": {
      "const": false
    },
    "records_real_client_evidence": {
      "const": false
    },
    "project_dir": {
      "type": ["string", "null"]
    },
    "output_dir": {
      "type": ["string", "null"]
    },
    "platform": {
      "type": ["string", "null"]
    },
    "mode": {
      "type": ["string", "null"]
    },
    "target_chapter": {
      "type": "integer",
      "minimum": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "needs_pack_repair",
        "needs_initialization",
        "needs_continuity_fix",
        "needs_author_review",
        "ready_to_start",
        "ready_for_read_only_start"
      ]
    },
    "can_draft": {
      "type": "boolean"
    },
    "summary": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "project_readiness",
        "desktop_next_step_status",
        "desktop_pack_readiness_status",
        "chapter_session_freshness_status",
        "agent_startup_prompt_status",
        "agent_takeover_status",
        "author_actions_status",
        "author_review_queue_status",
        "desktop_evidence_review_status",
        "chapter_session_status",
        "continuity_must_fix",
        "continuity_review",
        "read_error_count"
      ]
    },
    "next_action": {
      "type": "object",
      "additionalProperties": true
    },
    "do_first": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "first_files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/fileRef"
      }
    },
    "read_before_writing": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "commands": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/commandRef"
      }
    },
    "write_boundaries": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "starter_brief_is_read_only",
        "do_not_write_project_state_from_this_file",
        "read_only_agents_must_not_execute",
        "writer_actions_need_author_confirmation",
        "real_gui_evidence_is_separate_from_local_cli_checks",
        "remote_connector_only_platforms_are_outside_this_pack"
      ],
      "properties": {
        "starter_brief_is_read_only": {
          "const": true
        },
        "do_not_write_project_state_from_this_file": {
          "const": true
        },
        "read_only_agents_must_not_execute": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "writer_actions_need_author_confirmation": {
          "const": true
        },
        "real_gui_evidence_is_separate_from_local_cli_checks": {
          "const": true
        },
        "remote_connector_only_platforms_are_outside_this_pack": {
          "const": true
        }
      }
    },
    "source_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "read_errors": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "fileRef": {
      "type": "object",
      "additionalProperties": true,
      "required": ["file", "kind", "why"],
      "properties": {
        "file": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "why": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "commandRef": {
      "type": "object",
      "additionalProperties": true,
      "required": ["key", "present"],
      "properties": {
        "key": {
          "type": "string",
          "minLength": 1
        },
        "present": {
          "type": "boolean"
        },
        "stage": {
          "type": ["string", "null"]
        },
        "title": {
          "type": ["string", "null"]
        },
        "command": {
          "type": ["string", "null"]
        },
        "writes_project_state": {
          "type": "boolean"
        },
        "writes_install_config": {
          "type": "boolean"
        },
        "writes_pack_files": {
          "type": "boolean"
        },
        "requires_review": {
          "type": "boolean"
        },
        "requires_author_confirmation": {
          "type": "boolean"
        },
        "input_files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "output_files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
