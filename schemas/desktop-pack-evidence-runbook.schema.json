{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gaoxia.local/long-novel-agent/desktop-pack-evidence-runbook.schema.json",
  "title": "Long Novel Agent Desktop Evidence Runbook",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "$schema",
    "ok",
    "type",
    "generated_at",
    "local_only",
    "requires_server",
    "requires_real_desktop_client",
    "would_write_project_state",
    "would_write_install_config",
    "would_write_pack_files",
    "records_real_client_evidence",
    "platform",
    "mode",
    "tool_profile",
    "project_dir",
    "target_chapter",
    "evidence_file",
    "sanitized_evidence_file",
    "result_file",
    "imported_result_file",
    "required_check_ids",
    "allowed_statuses",
    "desktop_step_count",
    "desktop_steps",
    "preflight",
    "after_gui",
    "result_json_contract",
    "safety_notes"
  ],
  "properties": {
    "$schema": {
      "const": "desktop-evidence-runbook.schema.json"
    },
    "ok": {
      "type": "boolean"
    },
    "type": {
      "const": "desktop_evidence_runbook"
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "local_only": {
      "const": true
    },
    "requires_server": {
      "const": false
    },
    "requires_real_desktop_client": {
      "const": true
    },
    "would_write_project_state": {
      "const": false
    },
    "would_write_install_config": {
      "const": false
    },
    "would_write_pack_files": {
      "const": false
    },
    "records_real_client_evidence": {
      "const": false
    },
    "platform": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "enum": [
        "read-only",
        "writer"
      ]
    },
    "tool_profile": {
      "enum": [
        "core",
        "writing",
        "full"
      ]
    },
    "project_dir": {
      "type": "string",
      "minLength": 1
    },
    "target_chapter": {
      "type": "integer",
      "minimum": 1
    },
    "evidence_file": {
      "type": "string",
      "minLength": 1
    },
    "sanitized_evidence_file": {
      "type": "string",
      "minLength": 1
    },
    "result_file": {
      "type": "string",
      "minLength": 1
    },
    "imported_result_file": {
      "type": "string",
      "minLength": 1
    },
    "required_check_ids": {
      "$ref": "#/$defs/stringArray"
    },
    "allowed_statuses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": [
          "passed",
          "failed",
          "skipped",
          "not_checked"
        ]
      }
    },
    "desktop_step_count": {
      "type": "integer",
      "minimum": 1
    },
    "desktop_steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/desktopStep"
      }
    },
    "preflight": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/preflightStep"
      }
    },
    "after_gui": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/afterGuiStep"
      }
    },
    "result_json_contract": {
      "$ref": "#/$defs/resultJsonContract"
    },
    "safety_notes": {
      "$ref": "#/$defs/stringArray"
    }
  },
  "$defs": {
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "commandRef": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "key",
        "present",
        "command"
      ],
      "properties": {
        "key": {
          "type": "string",
          "minLength": 1
        },
        "present": {
          "type": "boolean"
        },
        "command": {
          "type": "string"
        }
      }
    },
    "desktopStep": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "step",
        "check_id",
        "required",
        "prompt",
        "result_status",
        "scratchpad_heading",
        "evidence_target"
      ],
      "properties": {
        "step": {
          "type": "integer",
          "minimum": 1
        },
        "check_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "phase": {
          "type": [
            "string",
            "null"
          ]
        },
        "required": {
          "type": "boolean"
        },
        "action": {
          "type": [
            "string",
            "null"
          ]
        },
        "expected": {
          "type": [
            "string",
            "null"
          ]
        },
        "evidence_needed": {
          "type": [
            "string",
            "null"
          ]
        },
        "prompt": {
          "type": "string",
          "minLength": 1
        },
        "result_status": {
          "type": "string",
          "minLength": 1
        },
        "scratchpad_heading": {
          "type": "string",
          "minLength": 1
        },
        "evidence_target": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "preflightStep": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "id",
        "title",
        "must_pass_before_recording"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "command": {
          "$ref": "#/$defs/commandRef"
        },
        "files": {
          "$ref": "#/$defs/stringArray"
        },
        "must_pass_before_recording": {
          "type": "boolean"
        }
      }
    },
    "afterGuiStep": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "id",
        "title",
        "writes_project_state"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "command": {
          "$ref": "#/$defs/commandRef"
        },
        "writes_project_state": {
          "type": "boolean"
        },
        "writes": {
          "$ref": "#/$defs/stringArray"
        }
      }
    },
    "resultJsonContract": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "status_values",
        "required_fields_per_check",
        "passed_requires_specific_evidence",
        "weak_evidence_examples"
      ],
      "properties": {
        "status_values": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": [
              "passed",
              "failed",
              "skipped",
              "not_checked"
            ]
          }
        },
        "required_fields_per_check": {
          "$ref": "#/$defs/stringArray"
        },
        "passed_requires_specific_evidence": {
          "const": true
        },
        "weak_evidence_examples": {
          "$ref": "#/$defs/stringArray"
        }
      }
    }
  }
}
