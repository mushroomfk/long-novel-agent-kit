{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gaoxia.local/long-novel-agent/desktop-pack-evidence-session.schema.json",
  "title": "Long Novel Agent Desktop Evidence Session",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "$schema",
    "ok",
    "type",
    "generated_at",
    "local_only",
    "requires_server",
    "requires_real_desktop_client",
    "would_write_project_state",
    "would_write_install_config",
    "would_write_pack_files",
    "records_real_client_evidence",
    "platform",
    "mode",
    "project_dir",
    "target_chapter",
    "result_file",
    "imported_result_file",
    "evidence_file",
    "sanitized_evidence_file",
    "required_check_ids",
    "allowed_statuses",
    "checks",
    "copy_prompts",
    "workflow",
    "commands",
    "write_boundaries",
    "notes"
  ],
  "properties": {
    "$schema": {
      "const": "desktop-evidence-session.schema.json"
    },
    "ok": {
      "type": "boolean"
    },
    "type": {
      "const": "desktop_evidence_session"
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "local_only": {
      "const": true
    },
    "requires_server": {
      "const": false
    },
    "requires_real_desktop_client": {
      "const": true
    },
    "would_write_project_state": {
      "const": false
    },
    "would_write_install_config": {
      "const": false
    },
    "would_write_pack_files": {
      "const": false
    },
    "records_real_client_evidence": {
      "const": false
    },
    "platform": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "enum": [
        "read-only",
        "writer"
      ]
    },
    "project_dir": {
      "type": "string",
      "minLength": 1
    },
    "target_chapter": {
      "type": "integer",
      "minimum": 1
    },
    "result_file": {
      "type": "string",
      "minLength": 1
    },
    "imported_result_file": {
      "type": "string",
      "minLength": 1
    },
    "evidence_file": {
      "type": "string",
      "minLength": 1
    },
    "sanitized_evidence_file": {
      "type": "string",
      "minLength": 1
    },
    "required_check_ids": {
      "$ref": "#/$defs/stringArray"
    },
    "allowed_statuses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": [
          "passed",
          "failed",
          "skipped",
          "not_checked"
        ]
      }
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/check"
      }
    },
    "copy_prompts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/copyPrompt"
      }
    },
    "workflow": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/workflowStep"
      }
    },
    "commands": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/commandRef"
      }
    },
    "write_boundaries": {
      "$ref": "#/$defs/writeBoundaries"
    },
    "notes": {
      "$ref": "#/$defs/stringArray"
    }
  },
  "$defs": {
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "check": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "id",
        "required",
        "prompt"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "phase": {
          "type": [
            "string",
            "null"
          ]
        },
        "required": {
          "type": "boolean"
        },
        "action": {
          "type": [
            "string",
            "null"
          ]
        },
        "expected": {
          "type": [
            "string",
            "null"
          ]
        },
        "evidence_needed": {
          "type": [
            "string",
            "null"
          ]
        },
        "command": {
          "type": "string"
        },
        "prompt": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "copyPrompt": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "check_id",
        "prompt",
        "evidence_target"
      ],
      "properties": {
        "check_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "prompt": {
          "type": "string",
          "minLength": 1
        },
        "evidence_target": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "workflowStep": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "step",
        "title",
        "file",
        "writes"
      ],
      "properties": {
        "step": {
          "type": "integer",
          "minimum": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "file": {
          "type": "string"
        },
        "command_key": {
          "type": "string"
        },
        "command": {
          "type": "string"
        },
        "writes": {
          "type": "string"
        }
      }
    },
    "commandRef": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "key",
        "command",
        "present"
      ],
      "properties": {
        "key": {
          "type": "string",
          "minLength": 1
        },
        "command": {
          "type": "string"
        },
        "present": {
          "type": "boolean"
        }
      }
    },
    "writeBoundaries": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "session_files_are_read_only_guidance",
        "desktop_evidence_packet_writes_project_state",
        "desktop_results_doctor_writes_project_state",
        "ingest_evidence_writes_project_state",
        "record_desktop_check_writes_project_state",
        "recording_requires_reviewed_real_client_evidence"
      ],
      "properties": {
        "session_files_are_read_only_guidance": {
          "const": true
        },
        "desktop_evidence_packet_writes_project_state": {
          "const": false
        },
        "desktop_results_doctor_writes_project_state": {
          "const": false
        },
        "ingest_evidence_writes_project_state": {
          "const": false
        },
        "record_desktop_check_writes_project_state": {
          "const": true
        },
        "recording_requires_reviewed_real_client_evidence": {
          "const": true
        }
      }
    }
  }
}
